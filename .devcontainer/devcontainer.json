{
  "name": "Aletheia Core",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postCreateCommand": "pip install -r requirements.txt && python main.py sign-manifest && echo '✅ Ready — run ./demo.sh'",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Aletheia API",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true
      }
    }
  }
}
