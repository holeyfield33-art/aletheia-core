# =============================================================================
# Aletheia Core — Environment Template (v1.9.3)
# Use this file as a source of truth for local + hosted setup.
# - Local dev: copy to .env.local
# - Render/Vercel: set these in each platform dashboard (do not upload .env files)
# Canonical reference: docs/ENVIRONMENT_VARIABLES.md
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime mode
# -----------------------------------------------------------------------------
ENVIRONMENT=development
ACTIVE_MODE=true
ALETHEIA_MODE=active

# -----------------------------------------------------------------------------
# NextAuth / frontend auth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-plus-char-secret
# AUTH_TRUST_HOST=true   # Required on Render/Railway/any non-Vercel host behind a reverse proxy

# OAuth providers (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/aletheia # pragma: allowlist secret
DIRECT_URL=postgresql://user:password@localhost:5432/aletheia # pragma: allowlist secret

# -----------------------------------------------------------------------------
# Core backend secrets
# -----------------------------------------------------------------------------
# Receipt signing (Ed25519)
# Set either inline PEM vars OR *_PATH vars (path is preferred in hosted envs).
# ALETHEIA_RECEIPT_PRIVATE_KEY=
# ALETHEIA_RECEIPT_PUBLIC_KEY=
# ALETHEIA_RECEIPT_PRIVATE_KEY_PATH=/var/secrets/receipt/receipt_ed25519.pem
# ALETHEIA_RECEIPT_PUBLIC_KEY_PATH=/var/secrets/receipt/receipt_ed25519.pub

# Legacy HMAC fallback used by startup checks and old-receipt verification.
# Keep this set in active mode until startup guard is fully Ed25519-native.
ALETHEIA_RECEIPT_SECRET=replace-with-strong-receipt-secret
ALETHEIA_ALIAS_SALT=replace-with-strong-alias-salt
ALETHEIA_ROTATION_SALT=replace-with-strong-rotation-salt
ALETHEIA_KEY_SALT=replace-with-strong-key-salt
# SIGNING_SECRET=
# ALETHEIA_MANIFEST_HASH=
# ALETHEIA_MANIFEST_KEY_VERSION=v1

# Manifest signing key management
# - Public key is committed at manifest/security_policy.ed25519.pub
# - Private key should stay outside git (for example .secrets/manifest/*.key)
# - After signing, set ALETHEIA_MANIFEST_HASH from sha256(manifest/security_policy.json)

# -----------------------------------------------------------------------------
# Backend routing/CORS/proxy
# -----------------------------------------------------------------------------
# ALETHEIA_BASE_URL=http://localhost:8000
# ALETHEIA_BACKEND_URL=http://localhost:8000
# ALETHEIA_ALLOWED_BACKEND_HOSTS=aletheia-core.onrender.com,app.aletheia-core.com
# ALETHEIA_CORS_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_CORS_ORIGIN=http://localhost:3000

# How many rightmost X-Forwarded-For entries are trusted infrastructure.
# Set to match your actual proxy chain — misconfiguration enables IP spoofing.
#   1 = single Render load balancer (default, no Cloudflare)
#   2 = Cloudflare + Render load balancer
#   0 = no proxy (direct connection)
# ALETHEIA_TRUSTED_PROXY_DEPTH=1    # Render: set to 1; Cloudflare+Render: set to 2

# Shared secret between Vercel proxy and Render backend.
# Render rejects internal-guarded /v1/* routes that do not carry this header.
# Public endpoint /v1/audit is exempt and continues to use API-key auth.
# Generate: openssl rand -hex 32
# Must be identical on Vercel (ALETHEIA_INTERNAL_SECRET) and Render.
# ALETHEIA_INTERNAL_SECRET=

# -----------------------------------------------------------------------------
# Production backend and secret backend options
# -----------------------------------------------------------------------------
# ALETHEIA_DATABASE_BACKEND=postgres
# ALETHEIA_SECRET_BACKEND=env
# ALETHEIA_ALLOW_ENV_SECRETS=true
# ALETHEIA_ALLOW_SQLITE_PRODUCTION=true
# ALETHEIA_FIPS_MODE=false

# -----------------------------------------------------------------------------
# Persistence and logging
# -----------------------------------------------------------------------------
# ALETHEIA_CONFIG_PATH=config.yaml
# ALETHEIA_AUDIT_LOG_PATH=audit.log
# ALETHEIA_DECISION_DB_PATH=data/aletheia_decisions.sqlite3
# ALETHEIA_KEYSTORE_PATH=data/keys.db
# ALETHEIA_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Rate limiting and distributed state (required in hosted production)
# -----------------------------------------------------------------------------
# ALETHEIA_RATE_LIMIT_PER_SECOND=10
# REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Semantic vector search (Qdrant)
# Required when ALETHEIA_SEMANTIC_ENABLED=true (Nitpicker v2 semantic mode).
# Local dev: run `docker compose up qdrant` (port 6333).
# Cloud:     use Qdrant Cloud cluster URL + API key.
# Build index first: python scripts/build_semantic_index.py
# -----------------------------------------------------------------------------
ALETHEIA_SEMANTIC_ENABLED=false
# ALETHEIA_QDRANT_URL=http://localhost:6333
# ALETHEIA_QDRANT_API_KEY=                          # leave blank for local dev
# ALETHEIA_QDRANT_COLLECTION=aletheia_semantic_patterns
# ALETHEIA_QDRANT_TIMEOUT_MS=120

# -----------------------------------------------------------------------------
# Optional AI/model integrations
# -----------------------------------------------------------------------------
# HUGGING_FACE_HUB_TOKEN=
# ALETHEIA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# ALETHEIA_MODEL_CACHE_DIR=~/.cache/aletheia/models

# -----------------------------------------------------------------------------
# Optional proximity/advanced modules
# -----------------------------------------------------------------------------
# CONSCIOUSNESS_PROXIMITY_ENABLED=true
# ALETHEIA_ANCHOR_STATE_PATH=data/anchor_state.json
# MNEME_URL=
# MNEME_API_KEY=
# GEOMETRIC_BRAIN_URL=

# -----------------------------------------------------------------------------
# Demo controls
# -----------------------------------------------------------------------------
# ALETHEIA_DEMO_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_DEMO_API_KEY=                # Required on Vercel for /api/demo proxy.
                                        # Also set on Render when the KeyStore is
                                        # SQLite on ephemeral disk so the lifespan
                                        # hook can re-seed it on every boot.
                                        # See docs/LAUNCH_GUIDE.md.
# ALETHEIA_SMOKE_TIMEOUT=15

# Render warm-up job (optional)
# ALETHEIA_WARMUP_URL=https://aletheia-core.onrender.com
# ALETHEIA_WARMUP_TIMEOUT_SECONDS=15
# ALETHEIA_WARMUP_DELAY_SECONDS=1.25

# -----------------------------------------------------------------------------
# Billing and email
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SCALE_PRICE_ID=
# STRIPE_SCALE_PRICE_AMOUNT=1900
# STRIPE_SCALE_CURRENCY=usd
STRIPE_PRO_PRICE_ID=
# STRIPE_PRO_PRICE_AMOUNT=4900
# STRIPE_PRO_CURRENCY=usd
# STRIPE_PAYG_METERED_PRICE_ID=
# STRIPE_PAYG_METERED_CURRENCY=usd
# CRON_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM="Aletheia Core <noreply@aletheia-core.com>"
