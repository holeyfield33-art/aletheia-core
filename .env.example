# =============================================================================
# Aletheia Core — Environment Configuration
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# --- Runtime Mode ---
# ENVIRONMENT=development  # Set to "production" for strict enforcement
# ALETHEIA_MODE=active     # "active" (enforce) or "shadow" (log only)

# --- Authentication (NextAuth.js) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=           # Generate: openssl rand -base64 32

# OAuth Providers (optional — credentials auth always works)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# --- Database (Supabase PostgreSQL) ---
# Transaction pooler (port 6543) — used at runtime by serverless functions
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection — used by Prisma migrations only
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- FastAPI Backend Auth ---
# ALETHEIA_API_KEYS=sk_admin_xxx,sk_admin_yyy   # Comma-separated admin API keys
# ALETHEIA_AUTH_DISABLED=true                     # Dev only; blocked in production

# --- Cryptographic Salts (REQUIRED in production) ---
# ALETHEIA_ALIAS_SALT=      # Judge alias bank rotation. Generate: openssl rand -hex 32
# ALETHEIA_KEY_SALT=         # API key hashing salt. Generate: openssl rand -hex 32
# ALETHEIA_ROTATION_SALT=    # Nitpicker per-request HMAC rotation. Generate: openssl rand -hex 32

# --- Receipt Signing ---
ALETHEIA_RECEIPT_SECRET=    # HMAC-SHA256 receipt signing key. Generate: openssl rand -hex 32

# --- Rate Limiting (Upstash Redis) ---
# Required in production. In-memory fallback used when not set (dev only).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# --- Metrics Endpoint Auth ---
# REQUIRED in production — /metrics returns 403 without this in production
# ALETHEIA_METRICS_TOKEN=    # Bearer token for /metrics endpoint. Generate: openssl rand -hex 32

# --- Stripe Billing (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Embedding Model ---
# HUGGING_FACE_HUB_TOKEN=   # Optional — for private models
# ALETHEIA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Key Store ---
# ALETHEIA_KEYSTORE_PATH=data/keys.db
# ALETHEIA_TRIAL_QUOTA=1000
# ALETHEIA_PRO_QUOTA=100000

# --- Policy Thresholds ---
# ALETHEIA_POLICY_THRESHOLD=7.5
# ALETHEIA_INTENT_THRESHOLD=0.55
# ALETHEIA_GREY_ZONE_LOWER=0.40
