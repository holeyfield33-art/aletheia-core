# =============================================================================
# Aletheia Core — Environment Configuration (v1.9.1)
# Copy this file to .env and fill in values for your environment.
# Canonical reference: docs/ENVIRONMENT_VARIABLES.md
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime mode
# -----------------------------------------------------------------------------
ENVIRONMENT=development            # production in hosted deployments
ACTIVE_MODE=true                   # recommended true in production
ALETHEIA_MODE=active              # active | shadow | monitor

# -----------------------------------------------------------------------------
# NextAuth / frontend auth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                   # required, 32+ chars (openssl rand -base64 32)
# AUTH_TRUST_HOST=true

# OAuth providers (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# -----------------------------------------------------------------------------
# Backend API/authn keys
# -----------------------------------------------------------------------------
# ALETHEIA_API_KEYS=sk_live_xxx,sk_live_yyy
# ALETHEIA_API_KEY=sk_live_xxx                       # single-key compatibility variable
ALETHEIA_ADMIN_KEY=                                  # required for admin endpoints
# ALETHEIA_AUTH_DISABLED=true                        # dev-only bypass (never production)

# -----------------------------------------------------------------------------
# Cryptographic secrets and signing
# -----------------------------------------------------------------------------
ALETHEIA_RECEIPT_SECRET=                             # required in hosted envs
# SIGNING_SECRET=                                    # strict production startup guard
# ALETHEIA_ALIAS_SALT=
# ALETHEIA_ROTATION_SALT=                            # Also accepts ALETHEIA_ALIAS_SALT (legacy fallback)
# ALETHEIA_KEY_SALT=
# ALETHEIA_MANIFEST_HASH=                            # optional pin for manifest/security_policy.json
# ALETHEIA_MANIFEST_KEY_VERSION=v1

# -----------------------------------------------------------------------------
# Backend routing/CORS/proxy
# -----------------------------------------------------------------------------
# ALETHEIA_BASE_URL=http://localhost:8000
# ALETHEIA_BACKEND_URL=http://localhost:8000
# ALETHEIA_ALLOWED_BACKEND_HOSTS=onrender.com,aletheia-core.com
# ALETHEIA_CORS_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_CORS_ORIGIN=http://localhost:3000
# ALETHEIA_TRUSTED_PROXY_DEPTH=1

# -----------------------------------------------------------------------------
# Production backend & secrets
# -----------------------------------------------------------------------------
# ALETHEIA_DATABASE_BACKEND=sqlite          # sqlite | postgres (postgres recommended for production)
# ALETHEIA_SECRET_BACKEND=env               # env | vault | aws | azure | gcp
# ALETHEIA_ALLOW_ENV_SECRETS=false          # set true to allow secret_backend=env in production

# -----------------------------------------------------------------------------
# Persistence and logging
# -----------------------------------------------------------------------------
# ALETHEIA_CONFIG_PATH=config.yaml
# ALETHEIA_AUDIT_LOG_PATH=audit.log
# ALETHEIA_DECISION_DB_PATH=data/aletheia_decisions.sqlite3
# ALETHEIA_KEYSTORE_PATH=data/keys.db
# ALETHEIA_LOG_LEVEL=INFO
# ALETHEIA_LOG_PII=false

# -----------------------------------------------------------------------------
# Rate limiting and distributed state
# -----------------------------------------------------------------------------
# ALETHEIA_RATE_LIMIT_PER_SECOND=10
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Optional AI/model integrations
# -----------------------------------------------------------------------------
# HUGGING_FACE_HUB_TOKEN=
# ALETHEIA_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Optional proximity/advanced modules
# -----------------------------------------------------------------------------
# CONSCIOUSNESS_PROXIMITY_ENABLED=true
# ALETHEIA_ANCHOR_STATE_PATH=data/anchor_state.json
# MNEME_URL=
# MNEME_API_KEY=
# GEOMETRIC_BRAIN_URL=

# -----------------------------------------------------------------------------
# Demo controls
# -----------------------------------------------------------------------------
# ALETHEIA_DEMO_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_DEMO_API_KEY=                # Required on Vercel for /api/demo proxy.
                                        # Also set on Render when the KeyStore is
                                        # SQLite on ephemeral disk so the lifespan
                                        # hook can re-seed it on every boot.
                                        # See docs/LAUNCH_GUIDE.md.
# ALETHEIA_SMOKE_TIMEOUT=15

# -----------------------------------------------------------------------------
# Billing and email
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_SCALE_PRICE_ID=
# STRIPE_SCALE_PRICE_AMOUNT=1900
# STRIPE_SCALE_CURRENCY=usd
# STRIPE_PRO_PRICE_ID=
# STRIPE_PRO_PRICE_AMOUNT=4900
# STRIPE_PRO_CURRENCY=usd
# STRIPE_PAYG_METERED_PRICE_ID=
# STRIPE_PAYG_METERED_CURRENCY=usd
# CRON_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM="Aletheia Core <noreply@aletheia-core.com>"
