# =============================================================================
# Aletheia Core — Environment Template (v1.9.2)
# Use this file as a source of truth for local + hosted setup.
# - Local dev: copy to .env.local
# - Render/Vercel: set these in each platform dashboard (do not upload .env files)
# Canonical reference: docs/ENVIRONMENT_VARIABLES.md
# =============================================================================

# -----------------------------------------------------------------------------
# Core runtime mode
# -----------------------------------------------------------------------------
ENVIRONMENT=development
ACTIVE_MODE=true
ALETHEIA_MODE=active

# -----------------------------------------------------------------------------
# NextAuth / frontend auth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-plus-char-secret
# AUTH_TRUST_HOST=true

# OAuth providers (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/aletheia # pragma: allowlist secret
DIRECT_URL=postgresql://user:password@localhost:5432/aletheia # pragma: allowlist secret

# -----------------------------------------------------------------------------
# Core backend secrets
# -----------------------------------------------------------------------------
ALETHEIA_RECEIPT_SECRET=replace-with-strong-receipt-secret
ALETHEIA_ALIAS_SALT=replace-with-strong-alias-salt
ALETHEIA_ROTATION_SALT=replace-with-strong-rotation-salt
ALETHEIA_KEY_SALT=replace-with-strong-key-salt
# SIGNING_SECRET=
# ALETHEIA_MANIFEST_HASH=
# ALETHEIA_MANIFEST_KEY_VERSION=v1

# -----------------------------------------------------------------------------
# Backend routing/CORS/proxy
# -----------------------------------------------------------------------------
# ALETHEIA_BASE_URL=http://localhost:8000
# ALETHEIA_BACKEND_URL=http://localhost:8000
# ALETHEIA_ALLOWED_BACKEND_HOSTS=aletheia-core.onrender.com,app.aletheia-core.com
# ALETHEIA_CORS_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_CORS_ORIGIN=http://localhost:3000
# ALETHEIA_TRUSTED_PROXY_DEPTH=1

# -----------------------------------------------------------------------------
# Production backend and secret backend options
# -----------------------------------------------------------------------------
# ALETHEIA_DATABASE_BACKEND=postgres
# ALETHEIA_SECRET_BACKEND=env
# ALETHEIA_ALLOW_ENV_SECRETS=true
# ALETHEIA_FIPS_MODE=false

# -----------------------------------------------------------------------------
# Persistence and logging
# -----------------------------------------------------------------------------
# ALETHEIA_CONFIG_PATH=config.yaml
# ALETHEIA_AUDIT_LOG_PATH=audit.log
# ALETHEIA_DECISION_DB_PATH=data/aletheia_decisions.sqlite3
# ALETHEIA_KEYSTORE_PATH=data/keys.db
# ALETHEIA_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Rate limiting and distributed state (required in hosted production)
# -----------------------------------------------------------------------------
# ALETHEIA_RATE_LIMIT_PER_SECOND=10
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Optional AI/model integrations
# -----------------------------------------------------------------------------
# HUGGING_FACE_HUB_TOKEN=
# ALETHEIA_EMBEDDING_MODEL=all-MiniLM-L6-v2
# ALETHEIA_MODEL_CACHE_DIR=~/.cache/aletheia/models

# -----------------------------------------------------------------------------
# Optional proximity/advanced modules
# -----------------------------------------------------------------------------
# CONSCIOUSNESS_PROXIMITY_ENABLED=true
# ALETHEIA_ANCHOR_STATE_PATH=data/anchor_state.json
# MNEME_URL=
# MNEME_API_KEY=
# GEOMETRIC_BRAIN_URL=

# -----------------------------------------------------------------------------
# Demo controls
# -----------------------------------------------------------------------------
# ALETHEIA_DEMO_ORIGINS=http://localhost:3000,https://app.aletheia-core.com
# ALETHEIA_DEMO_API_KEY=                # Required on Vercel for /api/demo proxy.
                                        # Also set on Render when the KeyStore is
                                        # SQLite on ephemeral disk so the lifespan
                                        # hook can re-seed it on every boot.
                                        # See docs/LAUNCH_GUIDE.md.
# ALETHEIA_SMOKE_TIMEOUT=15

# Render warm-up job (optional)
# ALETHEIA_WARMUP_URL=https://aletheia-core.onrender.com
# ALETHEIA_WARMUP_TIMEOUT_SECONDS=15
# ALETHEIA_WARMUP_DELAY_SECONDS=1.25

# -----------------------------------------------------------------------------
# Billing and email
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SCALE_PRICE_ID=
# STRIPE_SCALE_PRICE_AMOUNT=1900
# STRIPE_SCALE_CURRENCY=usd
STRIPE_PRO_PRICE_ID=
# STRIPE_PRO_PRICE_AMOUNT=4900
# STRIPE_PRO_CURRENCY=usd
# STRIPE_PAYG_METERED_PRICE_ID=
# STRIPE_PAYG_METERED_CURRENCY=usd
# CRON_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM="Aletheia Core <noreply@aletheia-core.com>"
